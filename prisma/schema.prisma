generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

enum Role {
  PENDING
  USER
  ADMIN
}

model User {
  id        String    @id @default(cuid())
  clerkId   String    @unique
  name      String?
  email     String    @unique
  image     String?
  role      Role      @default(PENDING)
  ownedCars Car[]     @relation("OwnedCars")
  trips     Trip[]
  payments  Payment[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Car {
  id             String      @id @default(cuid())
  name           String
  licensePlate   String?
  defaultGasCost Float       @default(0)
  ownerId        String
  owner          User        @relation("OwnedCars", fields: [ownerId], references: [id], onDelete: Cascade)
  trips        Trip[]
  dailyCosts   DailyCost[]
  payments     Payment[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

model Trip {
  id        String   @id @default(cuid())
  userId    String
  carId     String
  type      TripType
  date      DateTime @db.Date
  tappedAt  DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  car       Car      @relation(fields: [carId], references: [id], onDelete: Cascade)

  @@index([userId, carId, date])
  @@index([carId, date])
}

enum TripType {
  MORNING
  EVENING
}

model DailyCost {
  id          String   @id @default(cuid())
  carId       String
  date        DateTime @db.Date
  gasCost     Float    @default(0)
  parkingCost Float    @default(0)
  car         Car      @relation(fields: [carId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([carId, date])
}

model Payment {
  id        String   @id @default(cuid())
  userId    String
  carId     String
  amount    Float
  note      String?
  date      DateTime @db.Date
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  car       Car      @relation(fields: [carId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([carId])
}

model DisabledDate {
  id     String   @id @default(cuid())
  date   DateTime @unique @db.Date
  reason String?
}

/// Global system configuration (singleton-style, key-value)
model SystemConfig {
  id    String @id @default(cuid())
  key   String @unique
  value String
}
