generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

enum GroupRole {
  ADMIN
  MEMBER
}

enum MemberStatus {
  PENDING
  ACTIVE
}

model User {
  id          String              @id @default(cuid())
  clerkId     String              @unique
  name        String?
  email       String              @unique
  image       String?
  ownedCars   Car[]               @relation("OwnedCars")
  checkIns    CheckIn[]
  payments    Payment[]
  memberships PartyGroupMember[]
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
}

model PartyGroup {
  id           String              @id @default(cuid())
  name         String
  members      PartyGroupMember[]
  trips        Trip[]
  inviteTokens InviteToken[]
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
}

model PartyGroupMember {
  id           String       @id @default(cuid())
  userId       String
  partyGroupId String
  role         GroupRole    @default(MEMBER)
  status       MemberStatus @default(PENDING)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  partyGroup   PartyGroup   @relation(fields: [partyGroupId], references: [id], onDelete: Cascade)
  createdAt    DateTime     @default(now())

  @@unique([userId, partyGroupId])
  @@index([partyGroupId])
}

model InviteToken {
  id           String     @id @default(cuid())
  token        String     @unique @default(cuid())
  partyGroupId String
  partyGroup   PartyGroup @relation(fields: [partyGroupId], references: [id], onDelete: Cascade)
  expiresAt    DateTime
  createdAt    DateTime   @default(now())

  @@index([token])
}

model Car {
  id             String    @id @default(cuid())
  name           String
  licensePlate   String?
  defaultGasCost Float     @default(0)
  ownerId        String
  owner          User      @relation("OwnedCars", fields: [ownerId], references: [id], onDelete: Cascade)
  checkIns       CheckIn[]
  trips          Trip[]
  payments       Payment[]
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model CheckIn {
  id      String   @id @default(cuid())
  userId  String
  carId   String
  tripId  String?
  date    DateTime @db.Date
  tappedAt DateTime @default(now())
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  car     Car      @relation(fields: [carId], references: [id], onDelete: Cascade)
  trip    Trip?    @relation(fields: [tripId], references: [id])

  @@index([userId, carId, date])
  @@index([carId, date])
  @@map("CheckIn")
}

model Trip {
  id                    String      @id @default(cuid())
  carId                 String
  partyGroupId          String
  date                  DateTime    @db.Date
  gasCost               Float       @default(0)
  parkingCost           Float       @default(0)
  label                 String?
  sharedParkingTripIds  String[]    @default([])
  car                   Car         @relation(fields: [carId], references: [id], onDelete: Cascade)
  partyGroup            PartyGroup  @relation(fields: [partyGroupId], references: [id])
  checkIns              CheckIn[]
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt

  @@index([carId, date])
  @@index([partyGroupId])
  @@map("Trip")
}

model Payment {
  id        String   @id @default(cuid())
  userId    String
  carId     String
  amount    Float
  note      String?
  date      DateTime @db.Date
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  car       Car      @relation(fields: [carId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([carId])
  @@index([userId, date])
}
