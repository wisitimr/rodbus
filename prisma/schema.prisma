generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  cars          Car[]     @relation("OwnedCars")
  trips         Trip[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Car {
  id           String      @id @default(cuid())
  name         String
  licensePlate String?
  driverId     String
  driver       User        @relation("OwnedCars", fields: [driverId], references: [id], onDelete: Cascade)
  trips        Trip[]
  dailyCosts   DailyCost[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

model Trip {
  id        String   @id @default(cuid())
  userId    String
  carId     String
  type      TripType
  date      DateTime @db.Date
  tappedAt  DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  car       Car      @relation(fields: [carId], references: [id], onDelete: Cascade)

  @@index([userId, carId, date])
  @@index([carId, date])
}

enum TripType {
  MORNING
  EVENING
}

model DailyCost {
  id          String   @id @default(cuid())
  carId       String
  date        DateTime @db.Date
  gasCost     Float    @default(0)
  parkingCost Float    @default(0)
  car         Car      @relation(fields: [carId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([carId, date])
}
