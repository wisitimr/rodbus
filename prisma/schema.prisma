generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

enum GroupRole {
  ADMIN
  MEMBER
}

enum MemberStatus {
  PENDING
  ACTIVE
}

model User {
  id          String              @id @default(cuid())
  clerkId     String              @unique
  name        String?
  email       String              @unique
  image       String?
  ownedCars   Car[]               @relation("OwnedCars")
  checkIns    CheckIn[]
  payments    Payment[]
  memberships    PartyGroupMember[]
  ownedGroups  PartyGroup[]        @relation("OwnedGroups")
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
}

model PartyGroup {
  id           String              @id @default(cuid())
  name         String
  ownerId    String?
  owner      User?               @relation("OwnedGroups", fields: [ownerId], references: [id])
  members      PartyGroupMember[]
  trips        Trip[]
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
}

model PartyGroupMember {
  id           String       @id @default(cuid())
  userId       String
  partyGroupId String
  role         GroupRole    @default(MEMBER)
  status       MemberStatus @default(PENDING)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  partyGroup   PartyGroup   @relation(fields: [partyGroupId], references: [id], onDelete: Cascade)
  createdAt    DateTime     @default(now())

  @@unique([userId, partyGroupId])
  @@index([partyGroupId])
}

model Car {
  id             String    @id @default(cuid())
  name           String    @db.VarChar(20)
  licensePlate   String?
  defaultGasCost Float     @default(0)
  ownerId        String
  owner          User      @relation("OwnedCars", fields: [ownerId], references: [id], onDelete: Cascade)
  trips          Trip[]
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model CheckIn {
  id       String   @id @default(cuid())
  userId   String
  tripId   String
  tappedAt DateTime @default(now())
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  trip     Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([tripId])
  @@index([userId, tripId])
  @@map("CheckIn")
}

model Trip {
  id                    String      @id @default(cuid())
  carId                 String
  partyGroupId          String
  date                  DateTime    @db.Date
  gasCost               Float       @default(0)
  parkingCost           Float       @default(0)
  label                 String?
  sharedParkingTripIds  String[]    @default([])
  car                   Car         @relation(fields: [carId], references: [id], onDelete: Cascade)
  partyGroup            PartyGroup  @relation(fields: [partyGroupId], references: [id])
  checkIns              CheckIn[]
  payments              Payment[]
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt

  @@index([carId, date])
  @@index([partyGroupId])
  @@map("Trip")
}

model Payment {
  id        String   @id @default(cuid())
  userId    String
  tripId    String
  amount    Float
  note      String?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  trip      Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([tripId])
  @@index([userId, tripId])
}
